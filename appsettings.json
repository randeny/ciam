{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "https://proddepls.azurewebsites.net",
      "https://<native-auth-host>"
    ]
  },
  "Saml": {
    "ServiceProviderEntityId": "https://proddepls.azurewebsites.net/samlapp",
    "AssertionConsumerServiceUrl": "https://proddepls.azurewebsites.net/samlapp/acs",
    "ExpectedAudience": "urn:example:ps-saml-app",
    "MetadataUrl": "https://<tenant-subdomain>.ciamlogin.com/<tenant-id>/federationmetadata/2007-06/federationmetadata.xml?appid=adf88be4-b617-43c9-b1a9-de58d3baf543",
    "MetadataFilePath": "",
    "MetadataXml": "",
    "ValidateSignature": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "DetectReplay": true,
    "ClockSkewSeconds": 300
  },
  "PortalLogon": {
    "TenantSubdomain": "<tenant-subdomain>",
    "NativeAuthHost": "<native-auth-host>",
    "TenantId": "<tenant-id>",
    "OboClientId": "<app-B-client-id>",
    "OboClientSecret": "",
    "OboScope": "urn:example:ps-saml-app/access",
    "OboTokenUrl": "https://<native-auth-host>/<tenant-id>/oauth2/v2.0/token",
    "AcsUrl": "https://proddepls.azurewebsites.net/samlapp/acs"
  }
}
